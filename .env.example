# ── Convex ────────────────────────────────────────────────
# Run `npx convex dev` to generate these automatically
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Clerk Auth ───────────────────────────────────────────
# Get these from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Set this in Convex dashboard env vars too:
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-domain.clerk.accounts.dev

# ── Stripe Payments ──────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Set STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET in Convex env vars:
#   npx convex env set STRIPE_SECRET_KEY sk_test_...
#   npx convex env set STRIPE_WEBHOOK_SECRET whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_...

# ── Email (Resend) ───────────────────────────────────────
# Set in Convex env vars: npx convex env set RESEND_API_KEY re_...
# RESEND_FROM_EMAIL defaults to onboarding@resend.dev

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
